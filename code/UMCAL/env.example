# Optional environment configuration for the portable UMCAL core workflow.
#
# Use this file as a template:
#   copy to a local shell script
#   edit the values for your environment
#   source it before running UME_RCALL_V2.1.sh

# Root directory of the active UMCAL source tree.
# By default the workflow resolves this automatically from the script location.
export UME_SRC_DIR="$(pwd)/code/UMCAL/src"

# Set to 0 to disable SLURM submission and run the production stage locally.
# Keep as 1 to use sbatch when available.
export UME_USE_SLURM="0"

# Optional GBS summary file used by Discovery_enrichList_GBS.pl.
export UME_GBS_SUMMARY="/path/to/GBS_summary.txt"

# Optional repository root that contains Modules/VCF and Modules/Tassel.
# `UME_CARONTE_ROOT` is still accepted for backward compatibility.
export UME_REPO_ROOT="$(pwd)/code"

# Optional lookup table for the "sum" aggregation mode in discovery.
# The default active workflow uses "max", so this is only needed if that mode is enabled.
export UME_SUM_PVAL_TABLE="/path/to/Emp_Dist_sum.txt.pval2f"
