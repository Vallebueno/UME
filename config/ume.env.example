# Example environment for the public UME repository layout.
#
# Usage:
#   cp config/ume.env.example my-ume.env
#   edit my-ume.env
#   source my-ume.env

export UME_SRC_DIR="$(pwd)/code/UMCAL/src"
export UME_USE_SLURM="0"

# Optional GBS summary table used in discovery enrichment.
export UME_GBS_SUMMARY="/path/to/GBS_summary.txt"

# Optional external helper root containing Modules/.
export UME_CARONTE_ROOT="/path/to/Caronte/code"

# Optional sum-mode lookup table. Only needed if the discovery aggregation
# mode is changed from the current default.
export UME_SUM_PVAL_TABLE="/path/to/Emp_Dist_sum.txt.pval2f"

# Optional production output prefix for merged files.
export UME_PRODUCTION_PREFIX="MaizeDB_UME"
